  "edge_cases": [
    {
      "id": "edge-01",
      "description": "Ambiguous query should return a valid intent space",
      "query": "What are the rules?",
      "expected_status": "success",
      "expected_intent_spaces": ["hr", "legal", "finance", "general"]
    },
    {
      "id": "edge-02",
      "description": "Query with no matching document content still returns gracefully",
      "query": "What is the policy on adopting office pets?",
